{
  "name": "weak-cache-ts",
  "version": "1.1.1",
  "description": "Garbage-collectable cache for TypeScript/JavaScript using WeakRefs: synchronous and asynchronous object caching with auto-cleanup, deduplication, flexible keys (string/symbol), safe insertion modes, and GC-friendly memory management for browsers/Node.js.",
  "keywords": [
    "async-cache",
    "cache",
    "deduplication",
    "dispose",
    "finalizationregistry",
    "garbage-collection",
    "gc-friendly",
    "memoization",
    "memory-management",
    "object-cache",
    "observable",
    "promise",
    "promise-deduplication",
    "typescript",
    "watcher",
    "weak-cache",
    "weakref"
  ],
  "homepage": "https://github.com/orimay/weak-cache-ts#readme",
  "bugs": {
    "url": "https://github.com/orimay/weak-cache-ts/issues"
  },
  "license": "MIT",
  "author": "Dmitrii Baranov <dmitrii.a.baranov@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orimay/weak-cache-ts.git"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "bun --bun vitest",
    "typecheck": "tsc --noEmit",
    "release": "bun run test -- run && bun run build && bumpp && bun publish"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "@types/node": "^24.9.1",
    "bumpp": "^10.3.1",
    "tsdown": "^0.15.9",
    "typescript": "^5.9.3",
    "vitest": "^4.0.1"
  }
}
